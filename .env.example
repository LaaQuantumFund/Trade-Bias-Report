# ICT Daily / Weekly Bias — 環境変数テンプレート
# 使い方: cp .env.example .env して値を埋める
#
# Routines 環境では Anthropic UI の Environment variables に直接登録する（$CLAUDE_ENV_FILE は Setup script では
# 使えない。詳細は ~/HQ/infrastructure/routines-setup.md § 8 / § 14）。

# ---- 必須 ----

# Twelve Data API key（価格取得）。https://twelvedata.com/ で無料登録
TWELVEDATA_API_KEY=

# Anthropic API key（ローカル実行時のみ。Routines 環境は自動注入）
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ---- オプション（デフォルト値あり）----

# Obsidian Vault（Brain）のローカルパス
# ローカル実行時のレポート出力先。Routines 環境は clone 先を動的検出するため不要
OBSIDIAN_DAILY_PATH=~/Brain/Calendar/Daily-Bias
OBSIDIAN_WEEKLY_PATH=~/Brain/Calendar/Weekly-Bias

# Slack 通知先チャンネル（Routines 環境のみ。ローカル実行では Slack 通知をスキップ）
SLACK_NOTIFY_CHANNEL=#ceo
